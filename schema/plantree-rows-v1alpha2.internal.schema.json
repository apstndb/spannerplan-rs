{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/apstndb/spannerplan-rs/schema/plantree-rows-v1alpha2.internal.schema.json",
  "title": "Bundled viewer Plantree rows v1alpha2 response",
  "description": "Internal co-pinned viewer response. Success uses numeric wire revision 2 and occurrence-preserving rows; failures contain only an error string. No external compatibility is promised.",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["contractVersion", "rows"],
      "properties": {
        "contractVersion": {
          "const": 2
        },
        "rows": {
          "type": "array",
          "items": { "$ref": "#/$defs/row" }
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": ["error"],
      "properties": {
        "error": {
          "type": "string"
        }
      }
    }
  ],
  "$defs": {
    "row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rowId",
        "parentRowId",
        "nodeId",
        "treePart",
        "nodeText",
        "displayName",
        "predicates",
        "scalarChildLinks"
      ],
      "properties": {
        "rowId": { "type": "string", "pattern": "^0(?:\\.[0-9]+)*$" },
        "parentRowId": { "type": ["string", "null"] },
        "nodeId": { "type": "integer" },
        "treePart": { "type": "string" },
        "nodeText": { "type": "string" },
        "displayName": { "type": "string" },
        "predicates": {
          "type": "array",
          "items": { "type": "string" }
        },
        "scalarChildLinks": {
          "type": "array",
          "items": { "$ref": "#/$defs/childLink" }
        }
      }
    },
    "childLink": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "variable",
        "description",
        "displayName",
        "childIndex",
        "isPredicate"
      ],
      "properties": {
        "type": { "type": "string" },
        "variable": { "type": "string" },
        "description": { "type": "string" },
        "displayName": { "type": "string" },
        "childIndex": { "type": "integer" },
        "isPredicate": { "type": "boolean" }
      }
    }
  }
}
